# 生成员工列表
def generate_employees():
    employees = []
    emp_id = 1001
    
    for dept, info in TEAM_STRUCTURE.items():
        for level, count in info["职级分布"].items():
            for i in range(count):
                employees.append({
                    "员工ID": f"EMP{emp_id}",
                    "姓名": f"{dept}{level}{i+1}",
                    "部门": dept,
                    "职级": level,
                    "入职时间": (datetime(2022, 1, 1) + timedelta(days=random.randint(0, 900))).strftime("%Y-%m-%d"),
                    "技术栈": random.sample(info["技术栈"], k=random.randint(2, 4))
                })
                emp_id += 1
    
    return employees

