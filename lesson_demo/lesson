# ==================== 迭代数据 ====================

def generate_sprint_data():
    """生成迭代数据（6个双周迭代）"""
    sprints = []
    sprint_names = ["迭代1", "迭代2", "迭代3", "迭代4", "迭代5", "迭代6"]
    
    for i, name in enumerate(sprint_names):
        sprint = {
            "迭代名称": name,
            "开始日期": (datetime(2025, 1, 1) + timedelta(days=14*i)).strftime("%Y-%m-%d"),
            "结束日期": (datetime(2025, 1, 14) + timedelta(days=14*i)).strftime("%Y-%m-%d"),
            "计划需求数": random.randint(20, 30),
            "完成需求数": random.randint(18, 28),
            "计划故事点": random.randint(120, 180),
            "完成故事点": random.randint(110, 175),
            "缺陷数": random.randint(40, 70),
            "线上问题数": random.randint(0, 3)
        }
        sprint["需求完成率"] = round(sprint["完成需求数"] / sprint["计划需求数"], 2)
        sprint["故事点完成率"] = round(sprint["完成故事点"] / sprint["计划故事点"], 2)
        sprints.append(sprint)
    
    return sprints

