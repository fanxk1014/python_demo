# ==================== 个人效能数据 ====================

def generate_personal_metrics():
    """生成个人研发效能数据"""
    personal_metrics = []
    
    for emp in EMPLOYEES:
        # 根据职级设置基础系数
        level_factor = {"初级": 0.7, "中级": 1.0, "高级": 1.3, "专家": 1.6}[emp["职级"]]
        
        # 生成个人指标
        metrics = {
            "员工ID": emp["员工ID"],
            "姓名": emp["姓名"],
            "部门": emp["部门"],
            "职级": emp["职级"],
            "代码提交次数": int(random.gauss(80, 20) * level_factor),
            "代码新增行数": int(random.gauss(3500, 800) * level_factor),
            "Code Review次数": int(random.gauss(25, 8) * level_factor),
            "Bug修复数": int(random.gauss(15, 5) * level_factor),
            "Bug引入数": int(random.gauss(3, 1.5) * (2 - level_factor * 0.5)),
            "需求完成数": int(random.gauss(8, 2) * level_factor),
            "平均需求完成时长(天)": round(random.gauss(5, 1.5) / level_factor, 1),
            "加班时长(小时)": int(random.gauss(20, 10)),
            "技术分享次数": int(random.gauss(1, 0.8) * level_factor),
            "文档产出数": int(random.gauss(3, 1) * level_factor)
        }
        personal_metrics.append(metrics)
    
    return personal_metrics

